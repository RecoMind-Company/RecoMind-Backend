        sub_filter 'href="/swagger' 'href="/api/DbSetting/swagger';
        sub_filter 'src="/swagger' 'src="/api/DbSetting/swagger';

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # ========================================
