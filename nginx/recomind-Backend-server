# ========================================
# gRPC Server Configuration (HTTP/2)
# For internal service-to-service gRPC communication
# ========================================

server {
    # HTTP/2 is required for gRPC
    listen 50051 http2;
    listen [::]:50051 http2;
    server_name api.recomind.site;

    # SSL for secure gRPC (uncomment if needed)
    # ssl_certificate /etc/letsencrypt/live/api.recomind.site/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.recomind.site/privkey.pem;

    # gRPC-specific timeouts (1 hour for long-running streams)
    grpc_read_timeout 3600s;
    grpc_send_timeout 3600s;

    # ========================================
    # Authentication gRPC Service
    # Handles: AuthenticationService.proto, AccountService.proto
    # ========================================

    location /authentication. {
        grpc_pass grpc://authenticationservice_grpc_5011;

        # gRPC headers
        grpc_set_header Content-Type application/grpc;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /account. {
        grpc_pass grpc://authenticationservice_grpc_5011;

        grpc_set_header Content-Type application/grpc;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ========================================
    # Invitation gRPC Service
    # Handles: InvitationService.proto
    # ========================================

    location /invitation. {
        grpc_pass grpc://invitationservice_grpc_5006;

        grpc_set_header Content-Type application/grpc;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ========================================
    # Plan gRPC Service
    # Handles: PlanService.proto
    # ========================================

    location /plan. {
        grpc_pass grpc://planeservice_grpc_5005;

        grpc_set_header Content-Type application/grpc;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Default handler for unknown gRPC services
    location / {
        return 404;
    }
}
